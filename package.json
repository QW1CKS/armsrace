{
  "name": "armsrace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build:shared && node scripts/dev.mjs",
    "start": "npm run build:shared && node scripts/dev.mjs",
    "build": "npm run build --workspaces --if-present",
    "build:shared": "npm run build -w packages/shared",
    "typecheck": "tsc --noEmit -p packages/shared/tsconfig.json && tsc --noEmit -p packages/api/tsconfig.json && tsc --noEmit -p packages/worker/tsconfig.json && tsc --noEmit -p packages/web/tsconfig.json",
    "install:all": "npm install"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
