# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=development

# Path to SQLite database file (default: ./data/armsrace.db)
DB_PATH=

# Optional Redis URL for near-real-time SSE (falls back to in-memory if blank)
# Example: redis://localhost:6379
REDIS_URL=

# Set to false to disable auto-opening the browser on startup
OPEN_BROWSER=true

# ── API Keys (all optional — connectors gracefully skip if absent) ─────────────

# ACLED — Armed Conflict Location & Event Data (https://acleddata.com)
# Register at https://acleddata.com — uses OAuth 2.0 (email + password; tokens auto-refresh)
ACLED_EMAIL=
ACLED_PASSWORD=

# HAPI — Humanitarian API (https://hapi.humdata.org)
HAPI_APP_IDENTIFIER=

# AlienVault OTX (https://otx.alienvault.com)
OTX_API_KEY=

# AbuseIPDB (https://www.abuseipdb.com)
ABUSEIPDB_API_KEY=

# Finnhub — Stock market data (https://finnhub.io)
FINNHUB_API_KEY=

# FRED — Federal Reserve Economic Data (https://fred.stlouisfed.org/docs/api)
FRED_API_KEY=4eeca9a38f100d32ecff5ee4a674104f

# EIA — US Energy Information Administration (https://www.eia.gov/opendata)
EIA_API_KEY=

# AviationStack — Real-time flight data (https://aviationstack.com)
AVIATIONSTACK_API_KEY=

# ICAO — NOTAM data (https://applications.icao.int/dataservices)
ICAO_CLIENT_ID=
ICAO_CLIENT_SECRET=

# AIS — Maritime ship tracking (provider-dependent)
AIS_API_KEY=

# NGA — National Geospatial-Intelligence Agency (https://msi.nga.mil)
NGA_API_KEY=

# WHO — World Health Organization
WHO_API_KEY=

# NASA FIRMS — Fire Information for Resource Management System
# (free key at https://firms.modaps.eosdis.nasa.gov/api/area)
NASA_FIRMS_MAP_KEY=

# Wingbits — Aircraft enrichment
WINGBITS_API_KEY=

# Cloudflare Radar — Internet traffic analytics
CLOUDFLARE_API_TOKEN=

# Telegram MTProto — Channel aggregation (https://my.telegram.org)
# Run: npm run telegram:auth inside packages/worker to generate TELEGRAM_SESSION
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# Optional: AI provider for narrative enhancement (not required for base operation)
GROQ_API_KEY=
OPENROUTER_API_KEY=
